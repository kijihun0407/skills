# ========================================
# ai-ceo-os Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- AI Provider ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Social Media APIs ---
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=your_ad_account_id_here
META_IG_ACCESS_TOKEN=your_instagram_token_here

# --- Google ---
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id_here
GA4_PROPERTY_ID=your_ga4_property_id_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Communication ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
SLACK_BOT_TOKEN=your_slack_bot_token_here

# --- Database ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Deployment ---
VERCEL_TOKEN=your_vercel_token_here
