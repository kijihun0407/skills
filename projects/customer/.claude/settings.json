{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write(//**)",
      "Edit(//**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"고객관리 사업부 | $(git branch --show-current 2>/dev/null || echo 'no-git') | $(date '+%H:%M')\""
  },
  "env": {
    "PROJECT_VERSION": "0.1.0",
    "BUSINESS_UNIT": "customer"
  }
}
